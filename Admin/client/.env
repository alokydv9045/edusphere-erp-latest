# Admin Portal Frontend Environment Variables

# ============================================
# API CONFIGURATION
# ============================================
# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# WebSocket URL (if different from API)
NEXT_PUBLIC_WS_URL=http://localhost:5000

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# Application name
NEXT_PUBLIC_APP_NAME=EduSphere Admin Portal

# Application version
NEXT_PUBLIC_APP_VERSION=1.0.0

# Environment
NEXT_PUBLIC_ENV=development
# Options: development, staging, production

# ============================================
# FEATURE FLAGS
# ============================================
NEXT_PUBLIC_FEATURE_ANALYTICS=true
NEXT_PUBLIC_FEATURE_DARK_MODE=true
NEXT_PUBLIC_FEATURE_NOTIFICATIONS=true

# ============================================
# ANALYTICS & MONITORING
# ============================================
# Google Analytics
NEXT_PUBLIC_GA_ID=

# Sentry DSN (for error tracking)
NEXT_PUBLIC_SENTRY_DSN=

# ============================================
# AUTHENTICATION
# ============================================
# Token storage key
NEXT_PUBLIC_AUTH_TOKEN_KEY=admin_auth_token

# Session timeout (milliseconds)
NEXT_PUBLIC_SESSION_TIMEOUT=3600000
# 1 hour

# ============================================
# UI CONFIGURATION
# ============================================
# Default theme
NEXT_PUBLIC_DEFAULT_THEME=light
# Options: light, dark

# Items per page (pagination)
NEXT_PUBLIC_ITEMS_PER_PAGE=20

# ============================================
# MAP CONFIGURATION (Optional)
# ============================================
# Google Maps API Key (for school location)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ============================================
# CDN CONFIGURATION (Optional)
# ============================================
# CDN URL for assets
NEXT_PUBLIC_CDN_URL=

# ============================================
# DEVELOPMENT SETTINGS
# ============================================
# Enable debug mode
NEXT_PUBLIC_DEBUG=false

# Mock API responses (for development)
NEXT_PUBLIC_MOCK_API=false
