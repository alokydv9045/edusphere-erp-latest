# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development
# Options: development, production, staging

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection string
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres.gmmkmgpclbywifzvbwpi:bsdv5d5df15fd5g@aws-1-ap-south-1.pooler.supabase.com:5432/postgres"

# Connection pool settings (optional)
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ============================================
# JWT AUTHENTICATION
# ============================================
# Secret key for JWT token signing (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long-change-in-production
JWT_EXPIRES_IN=7d
# Options: 1h, 24h, 7d, 30d

# Refresh token settings
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# CORS CONFIGURATION
# ============================================
# Allowed origins (comma-separated for multiple)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# For production: https://admin.yourdomain.com,https://school1.yourdomain.com

# ============================================
# REDIS CONFIGURATION (Optional but recommended)
# ============================================
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
# Session cache expiry (seconds)
REDIS_SESSION_TTL=86400

# ============================================
# ADMIN USER CONFIGURATION
# ============================================
# Default admin user (created on first run)
ADMIN_EMAIL=admin@edusphere.com
ADMIN_PASSWORD=changeme123
ADMIN_FIRST_NAME=Super
ADMIN_LAST_NAME=Admin

# ============================================
# EMAIL CONFIGURATION (for notifications)
# ============================================
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=EduSphere Admin <noreply@edusphere.com>

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
# Local storage or cloud (s3, gcs, spaces)
STORAGE_TYPE=local
UPLOAD_DIR=./uploads
# Maximum file size in MB
MAX_FILE_SIZE=10

# AWS S3 Configuration (if STORAGE_TYPE=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=edusphere-admin-files

# Google Cloud Storage (if STORAGE_TYPE=gcs)
GCS_PROJECT_ID=
GCS_BUCKET=edusphere-admin-files
GCS_KEYFILE=./gcs-keyfile.json

# DigitalOcean Spaces (if STORAGE_TYPE=spaces)
SPACES_ENDPOINT=nyc3.digitaloceanspaces.com
SPACES_ACCESS_KEY=
SPACES_SECRET_KEY=
SPACES_BUCKET=edusphere-admin-files

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
# 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100
# Max requests per window

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=info
# Options: error, warn, info, http, verbose, debug, silly
LOG_FILE_ENABLED=true
LOG_DIR=./logs

# ============================================
# DATABASE PROVISIONING
# ============================================
# PostgreSQL admin credentials for creating school databases
PG_ADMIN_USER=postgres
PG_ADMIN_PASSWORD=postgres_admin_password
PG_HOST=localhost
PG_PORT=5432

# Default database settings for new schools
DEFAULT_DB_PREFIX=edusphere_school_

# ============================================
# PAYMENT GATEWAY (for subscriptions)
# ============================================
PAYMENT_ENABLED=false
PAYMENT_PROVIDER=stripe
# Options: stripe, razorpay, paypal

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Razorpay
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# ============================================
# MONITORING & ANALYTICS
# ============================================
MONITORING_ENABLED=false
SENTRY_DSN=
GOOGLE_ANALYTICS_ID=

# ============================================
# SECURITY SETTINGS
# ============================================
# Password requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=false

# Session settings
SESSION_SECRET=your-session-secret-change-in-production
SESSION_MAX_AGE=86400000
# 24 hours in milliseconds

# HTTPS enforcement
FORCE_HTTPS=false
# Set to true in production

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_SCHOOL_PROVISIONING=true
FEATURE_AUTO_BILLING=false
FEATURE_ANALYTICS_DASHBOARD=true
FEATURE_API_DOCUMENTATION=true

# ============================================
# TIMEZONE & LOCALIZATION
# ============================================
DEFAULT_TIMEZONE=Asia/Kolkata
DEFAULT_CURRENCY=INR
DEFAULT_LANGUAGE=en

# ============================================
# API CONFIGURATION
# ============================================
API_VERSION=v1
API_PREFIX=/api
API_DOCS_ENABLED=true
# Swagger docs available at /api-docs

# ============================================
# WEBHOOK CONFIGURATION
# ============================================
WEBHOOK_ENABLED=false
WEBHOOK_SCHOOL_CREATED_URL=
WEBHOOK_SUBSCRIPTION_UPDATED_URL=
WEBHOOK_SECRET=your-webhook-secret

# ============================================
# BACKUP CONFIGURATION
# ============================================
AUTO_BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 3 * * *
# Cron format: Daily at 3 AM
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/backups

# ============================================
# DEVELOPMENT SETTINGS (Development only!)
# ============================================
DEBUG_MODE=false
FAKE_EMAIL_ENABLED=false
# If true, emails are logged instead of sent (for testing)
