# School ERP Frontend Environment Variables

# ============================================
# API CONFIGURATION
# ============================================
# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:5001/api

# WebSocket URL (if different from API)
NEXT_PUBLIC_WS_URL=http://localhost:5001

# ============================================
# SCHOOL INFORMATION
# ============================================
# School ID (unique identifier)
NEXT_PUBLIC_SCHOOL_ID=demo-school

# School Name
NEXT_PUBLIC_SCHOOL_NAME=Demo School

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# Application name
NEXT_PUBLIC_APP_NAME=School ERP

# Application version
NEXT_PUBLIC_APP_VERSION=1.0.0

# Environment
NEXT_PUBLIC_ENV=development
# Options: development, staging, production

# ============================================
# FEATURE FLAGS
# ============================================
NEXT_PUBLIC_FEATURE_RFID_ATTENDANCE=true
NEXT_PUBLIC_FEATURE_EXAM_SYSTEM=true
NEXT_PUBLIC_FEATURE_FEE_MANAGEMENT=true
NEXT_PUBLIC_FEATURE_LIBRARY=true
NEXT_PUBLIC_FEATURE_INVENTORY=true
NEXT_PUBLIC_FEATURE_ANNOUNCEMENTS=true
NEXT_PUBLIC_FEATURE_PARENT_PORTAL=true
NEXT_PUBLIC_FEATURE_STUDENT_PORTAL=true
NEXT_PUBLIC_FEATURE_DARK_MODE=true

# ============================================
# ANALYTICS & MONITORING
# ============================================
# Google Analytics
NEXT_PUBLIC_GA_ID=

# Sentry DSN (for error tracking)
NEXT_PUBLIC_SENTRY_DSN=

# ============================================
# AUTHENTICATION
# ============================================
# Token storage key
NEXT_PUBLIC_AUTH_TOKEN_KEY=erp_auth_token

# Session timeout (milliseconds)
NEXT_PUBLIC_SESSION_TIMEOUT=3600000
# 1 hour

# Auto-logout on inactivity
NEXT_PUBLIC_AUTO_LOGOUT_ENABLED=true
NEXT_PUBLIC_INACTIVITY_TIMEOUT=1800000
# 30 minutes

# ============================================
# UI CONFIGURATION
# ============================================
# Default theme
NEXT_PUBLIC_DEFAULT_THEME=light
# Options: light, dark

# Items per page (pagination)
NEXT_PUBLIC_ITEMS_PER_PAGE=25

# Date format
NEXT_PUBLIC_DATE_FORMAT=DD/MM/YYYY
# Time format
NEXT_PUBLIC_TIME_FORMAT=HH:mm

# ============================================
# RFID ATTENDANCE DISPLAY
# ============================================
# Real-time attendance updates
NEXT_PUBLIC_REALTIME_ATTENDANCE=true

# Show attendance dashboard on login
NEXT_PUBLIC_SHOW_ATTENDANCE_DASHBOARD=true

# ============================================
# FEE MANAGEMENT
# ============================================
# Currency symbol
NEXT_PUBLIC_CURRENCY_SYMBOL=₹

# Show  payment gateway option
NEXT_PUBLIC_ONLINE_PAYMENT_ENABLED=false

# ============================================
# EXAM & RESULTS
# ============================================
# Show result publication date
NEXT_PUBLIC_SHOW_RESULT_PUBLISH_DATE=true

# Allow grade download
NEXT_PUBLIC_ALLOW_GRADE_DOWNLOAD=true

# ============================================
# PARENT PORTAL
# ============================================
# Features visible to parents
NEXT_PUBLIC_PARENT_VIEW_ATTENDANCE=true
NEXT_PUBLIC_PARENT_VIEW_GRADES=true
NEXT_PUBLIC_PARENT_VIEW_FEE=true
NEXT_PUBLIC_PARENT_VIEW_TIMETABLE=true
NEXT_PUBLIC_PARENT_RECEIVE_NOTIFICATIONS=true

# ============================================
# STUDENT PORTAL
# ============================================
# Features visible to students
NEXT_PUBLIC_STUDENT_VIEW_ATTENDANCE=true
NEXT_PUBLIC_STUDENT_VIEW_GRADES=true
NEXT_PUBLIC_STUDENT_VIEW_TIMETABLE=true
NEXT_PUBLIC_STUDENT_VIEW_LIBRARY=true
NEXT_PUBLIC_STUDENT_VIEW_FEE=false

# ============================================
# NOTIFICATION SETTINGS
# ============================================
# Browser notifications
NEXT_PUBLIC_BROWSER_NOTIFICATIONS=true

# Notification sound
NEXT_PUBLIC_NOTIFICATION_SOUND=true

# ============================================
# FILE UPLOAD
# ============================================
# Maximum file size (MB)
NEXT_PUBLIC_MAX_FILE_SIZE=10

# Allowed file types
NEXT_PUBLIC_ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx,xls,xlsx

# ============================================
# REPORT GENERATION
# ============================================
# Default export format
NEXT_PUBLIC_DEFAULT_EXPORT_FORMAT=pdf
# Options: pdf, excel, csv

# ============================================
# MAP CONFIGURATION (Optional)
# ============================================
# Google Maps API Key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ============================================
# HELP & SUPPORT
# ============================================
# Support email
NEXT_PUBLIC_SUPPORT_EMAIL=support@school.com

# Support phone
NEXT_PUBLIC_SUPPORT_PHONE=+91-1234567890

# Help documentation URL
NEXT_PUBLIC_HELP_URL=https://docs.edusphere.com

# ============================================
# CDN CONFIGURATION (Optional)
# ============================================
# CDN URL for assets
NEXT_PUBLIC_CDN_URL=

# ============================================
# DEVELOPMENT SETTINGS
# ============================================
# Enable debug mode
NEXT_PUBLIC_DEBUG=false

# Mock API responses (for development)
NEXT_PUBLIC_MOCK_API=false

# Show development tools
NEXT_PUBLIC_DEV_TOOLS=false
