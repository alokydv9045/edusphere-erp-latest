# ============================================================
# PRODUCTION ENVIRONMENT VARIABLES FOR VERCEL
# Copy this file as .env.production and fill in actual values
# Set these in Vercel Dashboard → Project → Settings → Environment Variables
# ============================================================

# ---- REQUIRED ----

# Your Render server URL (e.g. https://edusphere-server.onrender.com/api)
NEXT_PUBLIC_API_URL=https://your-render-server.onrender.com/api

NEXT_PUBLIC_WS_URL=https://your-render-server.onrender.com

# ---- CONFIGURATION KEYS ----
# These should match the keys in the SchoolBranding DB table if customized
NEXT_PUBLIC_SCHOOL_START_TIME=08:30
NEXT_PUBLIC_PASSING_PERCENTAGE=40
NEXT_PUBLIC_FEE_CURRENCY=INR

# ---- SCHOOL INFO ----
NEXT_PUBLIC_SCHOOL_ID=your-school-id
NEXT_PUBLIC_SCHOOL_NAME=Your School Name

# ---- APP SETTINGS ----
NEXT_PUBLIC_APP_NAME=EduSphere ERP
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_ENV=production

# ---- FEATURE FLAGS ----
NEXT_PUBLIC_FEATURE_RFID_ATTENDANCE=true
NEXT_PUBLIC_FEATURE_EXAM_SYSTEM=true
NEXT_PUBLIC_FEATURE_FEE_MANAGEMENT=true
NEXT_PUBLIC_FEATURE_LIBRARY=true
NEXT_PUBLIC_FEATURE_INVENTORY=true
NEXT_PUBLIC_FEATURE_ANNOUNCEMENTS=true
NEXT_PUBLIC_FEATURE_PARENT_PORTAL=true
NEXT_PUBLIC_FEATURE_STUDENT_PORTAL=true
NEXT_PUBLIC_FEATURE_DARK_MODE=true

# ---- AUTH ----
NEXT_PUBLIC_AUTH_TOKEN_KEY=erp_auth_token
NEXT_PUBLIC_SESSION_TIMEOUT=3600000
NEXT_PUBLIC_AUTO_LOGOUT_ENABLED=true
NEXT_PUBLIC_INACTIVITY_TIMEOUT=1800000

# ---- UI ----
NEXT_PUBLIC_DEFAULT_THEME=light
NEXT_PUBLIC_ITEMS_PER_PAGE=25
NEXT_PUBLIC_DATE_FORMAT=DD/MM/YYYY
NEXT_PUBLIC_TIME_FORMAT=HH:mm
NEXT_PUBLIC_CURRENCY_SYMBOL=₹

# ---- OPTIONAL: Analytics ----
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_SENTRY_DSN=
