# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5001
NODE_ENV=development
# Options: development, production, staging

# ============================================
# SCHOOL INFORMATION
# ============================================
SCHOOL_ID=demo-school
# Unique identifier for this school instance
SCHOOL_NAME=Demo School
SCHOOL_CODE=DEMO001

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection string
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://username:password@localhost:5432/edusphere_school_demo"

# Connection pool settings (optional)
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ============================================
# JWT AUTHENTICATION
# ============================================
# Secret key for JWT token signing (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long-change-in-production
JWT_EXPIRES_IN=7d
# Options: 1h, 24h, 7d, 30d

# Refresh token settings
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# CORS CONFIGURATION
# ============================================
# Allowed origins (comma-separated for multiple)
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000
# For production: https://school1.yourdomain.com

# ============================================
# REDIS CONFIGURATION (Optional but recommended)
# ============================================
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
# Session cache expiry (seconds)
REDIS_SESSION_TTL=86400

# ============================================
# RFID CONFIGURATION
# ============================================
# Enable/disable RFID attendance system
RFID_ENABLED=true

# Connection type: serial, network
RFID_CONNECTION_TYPE=serial

# Serial/USB Reader Configuration
RFID_READER_PORT=/dev/ttyUSB0
# Linux: /dev/ttyUSB0, /dev/ttyACM0
# Windows: COM3, COM4
RFID_READER_BAUDRATE=9600
# Common: 9600, 115200

# Network Reader Configuration (if RFID_CONNECTION_TYPE=network)
RFID_READER_URL=http://192.168.1.100:8080
RFID_READER_API_KEY=

# Attendance Settings
RFID_AUTO_MARK_ATTENDANCE=true
# Prevent duplicate scans within interval (seconds)
RFID_DUPLICATE_SCAN_INTERVAL=300

# Notification settings
RFID_NOTIFY_PARENTS=true
RFID_NOTIFY_ADMINS=false

# School timing (for late detection)
SCHOOL_START_TIME=08:30
SCHOOL_END_TIME=15:30

# ============================================
# ACADEMIC CONFIGURATION
# ============================================
# Academic year start month (1-12)
ACADEMIC_YEAR_START_MONTH=4
# Weekend days (comma-separated: 0=Sunday, 6=Saturday)
WEEKEND_DAYS=0,6
# Working days per week
WORKING_DAYS_PER_WEEK=6

# ============================================
# ATTENDANCE CONFIGURATION
# ============================================
# Automatic absence marking time
AUTO_MARK_ABSENT_TIME=10:00
# Mark as late after this time
LATE_ARRIVAL_TIME=08:45
# Half-day threshold (in minutes)
HALF_DAY_THRESHOLD=240

# ============================================
# FEE MANAGEMENT CONFIGURATION
# ============================================
# Default currency
FEE_CURRENCY=INR
# Late fee after due date (days)
LATE_FEE_GRACE_PERIOD=5
# Default late fee percentage
LATE_FEE_PERCENTAGE=2

# ============================================
# LIBRARY CONFIGURATION
# ============================================
# Default book issue period (days)
LIBRARY_DEFAULT_ISSUE_DAYS=14
# Fine per day for overdue books
LIBRARY_FINE_PER_DAY=5
# Maximum books per student
LIBRARY_MAX_BOOKS_PER_STUDENT=3

# ============================================
# EXAMINATION CONFIGURATION
# ============================================
# Grade calculation method: percentage, cgpa, gpa
GRADE_CALCULATION_METHOD=percentage
# Passing percentage
PASSING_PERCENTAGE=40
# Enable rank calculation
ENABLE_RANK_CALCULATION=true

# ============================================
# EMAIL CONFIGURATION
# ============================================
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=School ERP <noreply@school.com>

# Email templates
EMAIL_ATTENDANCE_NOTIFICATION=true
EMAIL_FEE_REMINDER=true
EMAIL_EXAM_RESULTS=true

# ============================================
# SMS CONFIGURATION (Optional)
# ============================================
SMS_ENABLED=false
SMS_PROVIDER=twilio
# Options: twilio, aws_sns, msg91

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# MSG91 (India)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=

# SMS notifications
SMS_ATTENDANCE_NOTIFICATION=false
SMS_FEE_REMINDER=false

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
# Storage type: local, s3, gcs, spaces
STORAGE_TYPE=local
UPLOAD_DIR=./uploads
# Maximum file size in MB
MAX_FILE_SIZE=10

# Allowed file types
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx,xls,xlsx

# AWS S3 Configuration (if STORAGE_TYPE=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=edusphere-school-files

# Google Cloud Storage (if STORAGE_TYPE=gcs)
GCS_PROJECT_ID=
GCS_BUCKET=edusphere-school-files
GCS_KEYFILE=./gcs-keyfile.json

# DigitalOcean Spaces (if STORAGE_TYPE=spaces)
SPACES_ENDPOINT=nyc3.digitaloceanspaces.com
SPACES_ACCESS_KEY=
SPACES_SECRET_KEY=
SPACES_BUCKET=edusphere-school-files

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
# 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=200
# Max requests per window

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=info
# Options: error, warn, info, http, verbose, debug, silly
LOG_FILE_ENABLED=true
LOG_DIR=./logs
# Enable request logging
LOG_HTTP_REQUESTS=true

# ============================================
# WEBSOCKET CONFIGURATION
# ============================================
WEBSOCKET_ENABLED=true
WEBSOCKET_PORT=
# If not set, uses same port as HTTP server
WEBSOCKET_PATH=/socket.io

# ============================================
# SECURITY SETTINGS
# ============================================
# Password requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=false

# Session settings
SESSION_SECRET=your-session-secret-change-in-production
SESSION_MAX_AGE=86400000
# 24 hours in milliseconds

# HTTPS enforcement
FORCE_HTTPS=false
# Set to true in production

# CSRF protection
CSRF_ENABLED=true

# ============================================
# REPORT GENERATION
# ============================================
# Report format: pdf, excel, both
DEFAULT_REPORT_FORMAT=pdf
# Report storage
REPORT_STORAGE_DIR=./reports
# Auto-delete reports after (days)
REPORT_RETENTION_DAYS=30

# ============================================
# PARENT PORTAL SETTINGS
# ============================================
PARENT_PORTAL_ENABLED=true
# Features accessible to parents
PARENT_VIEW_ATTENDANCE=true
PARENT_VIEW_GRADES=true
PARENT_VIEW_FEE_STATUS=true
PARENT_VIEW_TIMETABLE=true
PARENT_DOWNLOAD_REPORTS=true

# ============================================
# STUDENT PORTAL SETTINGS
# ============================================
STUDENT_PORTAL_ENABLED=true
# Features accessible to students
STUDENT_VIEW_ATTENDANCE=true
STUDENT_VIEW_GRADES=true
STUDENT_VIEW_TIMETABLE=true
STUDENT_VIEW_ASSIGNMENTS=true

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_ATTENDANCE_SYSTEM=true
FEATURE_EXAM_SYSTEM=true
FEATURE_FEE_SYSTEM=true
FEATURE_LIBRARY_SYSTEM=true
FEATURE_INVENTORY_SYSTEM=true
FEATURE_TIMETABLE_SYSTEM=true
FEATURE_ANNOUNCEMENTS=true
FEATURE_REPORTS=true

# ============================================
# NOTIFICATION SETTINGS
# ============================================
# Daily attendance summary time
DAILY_ATTENDANCE_SUMMARY_TIME=16:00
# Fee due reminder days before
FEE_REMINDER_DAYS_BEFORE=7,3,1
# Exam reminder days before
EXAM_REMINDER_DAYS_BEFORE=7,3,1

# ============================================
# TIMEZONE & LOCALIZATION
# ============================================
TIMEZONE=Asia/Kolkata
CURRENCY=INR
LANGUAGE=en
DATE_FORMAT=DD/MM/YYYY
TIME_FORMAT=HH:mm

# ============================================
# API CONFIGURATION
# ============================================
API_VERSION=v1
API_PREFIX=/api
API_DOCS_ENABLED=true
# Swagger docs available at /api-docs

# ============================================
# MONITORING & ANALYTICS
# ============================================
MONITORING_ENABLED=false
SENTRY_DSN=
GOOGLE_ANALYTICS_ID=

# ============================================
# BACKUP CONFIGURATION
# ============================================
AUTO_BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
# Cron format: Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/backups

# ============================================
# INTEGRATION SETTINGS
# ============================================
# Biometric attendance integration
BIOMETRIC_ENABLED=false
BIOMETRIC_DEVICE_TYPE=
# Options: fingerprint, face_recognition

# Payment gateway integration
PAYMENT_GATEWAY_ENABLED=false
PAYMENT_GATEWAY_PROVIDER=razorpay
# Options: razorpay, stripe, paytm

# Razorpay
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# ============================================
# CRON JOBS
# ============================================
CRON_ENABLED=true
# Auto mark absent students (daily)
CRON_AUTO_MARK_ABSENT=0 10 * * 1-6
# Generate attendance reports (daily)
CRON_ATTENDANCE_REPORT=0 17 * * 1-6
# Fee reminder (weekly)
CRON_FEE_REMINDER=0 9 * * 1
# Database cleanup (monthly)
CRON_DB_CLEANUP=0 1 1 * *

# ============================================
# DEVELOPMENT SETTINGS (Development only!)
# ============================================
DEBUG_MODE=false
FAKE_EMAIL_ENABLED=false
# If true, emails are logged instead of sent
MOCK_RFID_ENABLED=false
# If true, simulates RFID scans for testing
